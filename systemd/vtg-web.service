[Unit]
Description=VTG Web Test UI
After=network.target vtg-video.service vtg-audio.service

[Service]
Type=simple
User=vtg
WorkingDirectory=/home/vtg/vtg_gen2/services
ExecStart=/usr/bin/python3 /home/vtg/vtg_gen2/services/web_api.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target